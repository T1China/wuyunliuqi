/* pages/profile/profile.wxss */
.page { min-height:100vh; background:#1A2744; padding:32rpx 32rpx 120rpx; }
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-accent);
  margin-bottom: 32rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}
.empty-icon {
  font-size: 96rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.empty-sub {
  font-size: 24rpx;
  color: rgba(144,164,174,0.6);
}

/* 历史条目 */
.history-item {
  position: relative;
  margin-bottom: 16rpx;
  padding: 24rpx 80rpx 24rpx 32rpx;
  cursor: pointer;
}
.history-item:active { opacity: 0.7; }
.history-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.history-label {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.birth-label   { background: rgba(255,215,0,0.2); color: #FFD700; }
.disease-label { background: rgba(244,67,54,0.2);  color: #F44336; }
.history-date {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.history-time {
  display: block;
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}
.history-arrow {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: var(--text-secondary);
}

/* 清除按钮 */
.clear-btn {
  text-align: center;
  padding: 28rpx;
  color: rgba(244,67,54,0.6);
  font-size: 26rpx;
  margin-top: 16rpx;
}

/* 关于 */
.about-card {
  margin-top: 40rpx;
  background: rgba(255,255,255,0.03);
}
.about-title {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.about-text {
  font-size: 24rpx;
  color: rgba(144,164,174,0.7);
  line-height: 1.8;
}

/* pages/home/home.wxss */
.page { min-height:100vh; background:#1A2744; padding:0 28rpx 140rpx; }

/* ── 顶部 ── */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 48rpx 8rpx 24rpx;
}
.header-date {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #E8EAF6;
}
.header-gz {
  display: block;
  font-size: 24rpx;
  color: #90A4AE;
  margin-top: 6rpx;
}
.header-year {
  font-size: 72rpx;
  font-weight: 900;
  color: rgba(255,215,0,0.15);
  letter-spacing: -4rpx;
}

/* ── 主卡片 ── */
.main-card {
  background: linear-gradient(145deg, #1A2B3C, #0F2030);
  border: 1rpx solid rgba(255,215,0,0.18);
  border-radius: 28rpx;
  padding: 36rpx 32rpx 28rpx;
  margin-bottom: 24rpx;
}
.main-card-title {
  font-size: 22rpx;
  color: #FFD700;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
  font-weight: 600;
}
.ganzhi-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.ganzhi-text {
  font-size: 72rpx;
  font-weight: 900;
  color: #E8EAF6;
  letter-spacing: 8rpx;
}
.wuxing-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
}
.wuxing-text {
  font-size: 36rpx;
  font-weight: 900;
}

/* 四格 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.info-cell {
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
  padding: 20rpx 18rpx;
}
.info-label {
  display: block;
  font-size: 20rpx;
  color: #90A4AE;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}
.info-val {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #E8EAF6;
  margin-bottom: 6rpx;
  line-height: 1.3;
}
.info-val.accent-text { color: #FFD700; }
.info-num {
  display: block;
  font-size: 20rpx;
  color: #90A4AE;
  font-family: monospace;
  letter-spacing: 2rpx;
}

/* ── 节气卡片 ── */
.jieqi-card {
  background: linear-gradient(135deg, #1B2D1B, #0F200F);
  border: 1rpx solid rgba(76,175,80,0.35);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}
.jieqi-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.jieqi-tip {
  display: block;
  font-size: 22rpx;
  color: rgba(76,175,80,0.7);
  margin-bottom: 8rpx;
}
.jieqi-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #4CAF50;
}
.jieqi-count { text-align: right; }
.jieqi-num {
  display: block;
  font-size: 80rpx;
  font-weight: 900;
  color: #4CAF50;
  line-height: 1;
}
.jieqi-unit {
  font-size: 24rpx;
  color: rgba(76,175,80,0.7);
}

/* ── 年度六气 ── */
.section-card {
  background: #1A2B3C;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 12rpx;
  margin-bottom: 32rpx;
}
.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #FFD700;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}
.seg-list { }
.seg-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  opacity: 0.45;
}
.seg-active {
  background: rgba(255,215,0,0.08);
  opacity: 1;
  border-left: 4rpx solid #FFD700;
  padding-left: 20rpx;
}
.seg-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #E8EAF6;
  margin-bottom: 4rpx;
}
.seg-date {
  display: block;
  font-size: 20rpx;
  color: #90A4AE;
}
.seg-right { text-align: right; }
.seg-qi {
  display: block;
  font-size: 24rpx;
  color: #E8EAF6;
  margin-bottom: 4rpx;
}
.seg-ke {
  display: block;
  font-size: 20rpx;
  color: #90A4AE;
}
.seg-active .seg-label,
.seg-active .seg-qi { color: #FFD700; }

/* ── CTA ── */
.cta-btn {
  background: linear-gradient(135deg, #FFD700, #FF8F00);
  border-radius: 24rpx;
  padding: 36rpx;
  text-align: center;
  margin-bottom: 16rpx;
}
.cta-btn:active { opacity: 0.85; transform: scale(0.98); }
.cta-text {
  font-size: 34rpx;
  font-weight: 800;
  color: #0D1B2A;
  letter-spacing: 6rpx;
}

/* 可点击术语 */
.clickable { border-bottom: 1rpx solid rgba(255,215,0,0.35); padding-bottom: 2rpx; }

/* ── 原生底部弹窗 ── */
.popup-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0);
  z-index: 10000;
  pointer-events: none;
  transition: background 0.28s;
}
.popup-mask-show {
  background: rgba(0,0,0,0.55);
  pointer-events: auto;
}
.popup-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  z-index: 10001;
  background: #1C2D52;
  border-radius: 32rpx 32rpx 0 0;
  border-top: 2rpx solid rgba(255,215,0,0.28);
  transform: translateY(100%);
  transition: transform 0.30s cubic-bezier(0.32,0.72,0,1);
  max-height: 75vh;
  overflow: hidden;
}
.popup-sheet-show { transform: translateY(0); }
.popup-bar {
  display: flex; align-items: center; justify-content: center;
  padding: 20rpx 28rpx 8rpx;
  position: relative;
}
.popup-drag-handle {
  width: 72rpx; height: 8rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 4rpx;
}
.popup-close-btn {
  position: absolute; right: 28rpx; top: 16rpx;
  padding: 10rpx 14rpx;
}
.popup-close-x { font-size: 34rpx; color: #64909A; }

/* 弹窗内容 */
.explain-popup { padding: 16rpx 36rpx 60rpx; overflow-y: auto; max-height: calc(75vh - 80rpx); }
.ep-title { font-size: 40rpx; font-weight: 800; color: #FFD700; margin-bottom: 12rpx; letter-spacing: 2rpx; }
.ep-subtitle { font-size: 24rpx; color: #94B8D0; margin-bottom: 24rpx; line-height: 1.5; }
.ep-body { font-size: 28rpx; color: #E8F4F8; line-height: 1.9; white-space: pre-wrap; }

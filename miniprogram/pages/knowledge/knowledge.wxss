/* pages/knowledge/knowledge.wxss */
.page { min-height:100vh; background:#1A2744; padding-bottom:120rpx; }

.tab-bar { display:flex; background:#243560; }
.tab-item { flex:1; text-align:center; padding:30rpx 0; font-size:32rpx; color:#94B8D0; position:relative; }
.tab-on { color:#FFD700; font-weight:700; }
.tab-on::after { content:''; position:absolute; bottom:0; left:20%; right:20%; height:4rpx; background:#FFD700; border-radius:2rpx; }

.tab-body { padding:20rpx 28rpx; }

/* 六气卡片 */
.qi-card { background:#243560; border-radius:20rpx; margin-bottom:20rpx; overflow:hidden; }
.qi-head { padding:24rpx 28rpx 16rpx 24rpx; }
.qi-name { display:block; font-size:36rpx; font-weight:800; margin-bottom:6rpx; }
.qi-organ { font-size:24rpx; color:#94B8D0; }
.qi-body { padding:0 28rpx 24rpx; }
.qi-section { margin-bottom:16rpx; display:flex; align-items:flex-start; }
.qs-label { width:64rpx; font-size:20rpx; font-weight:700; padding:4rpx 10rpx; border-radius:6rpx; margin-right:14rpx; flex-shrink:0; text-align:center; margin-top:2rpx; }
.nature-label  { background:rgba(100,180,255,0.15); color:#64B4FF; }
.disease-label { background:rgba(244,67,54,0.15);  color:#F44336; }
.nourish-label { background:rgba(76,175,80,0.15);  color:#4CAF50; }
.qs-text { flex:1; font-size:26rpx; color:#C8D8E8; line-height:1.7; }
.disease-text { color:#EF9A9A; }
.nourish-text { color:#A5D6A7; }

/* 五行卡片 */
.wx-card { background:#243560; border-radius:20rpx; margin-bottom:20rpx; overflow:hidden; padding:24rpx 28rpx; }
.wx-head { display:flex; align-items:center; margin-bottom:20rpx; }
.wx-badge { width:80rpx; height:80rpx; border-radius:50%; display:flex; align-items:center; justify-content:center; margin-right:20rpx; flex-shrink:0; }
.wx-el { font-size:40rpx; font-weight:900; }
.wx-zang { display:block; font-size:30rpx; font-weight:700; color:#E8F4F8; margin-bottom:10rpx; }
.wx-tags { display:flex; gap:12rpx; }
.wx-tag { font-size:22rpx; color:#94B8D0; background:rgba(255,255,255,0.06); padding:4rpx 14rpx; border-radius:20rpx; }
.wx-body { }

/* 理论 */
.theory-card { background:#243560; border-radius:20rpx; padding:28rpx; margin-bottom:20rpx; }
.theory-title { display:block; font-size:30rpx; font-weight:700; color:#FFD700; margin-bottom:16rpx; }
.theory-text { display:block; font-size:26rpx; color:#C8D8E8; line-height:1.9; }

/* 数字表 */
.num-table { background:#243560; border-radius:20rpx; padding:20rpx 28rpx; margin-bottom:20rpx; }
.num-row { display:grid; grid-template-columns:1fr 1fr 1.3fr 1.3fr; padding:14rpx 0; font-size:28rpx; text-align:center; border-bottom:1rpx solid rgba(255,255,255,0.06); }
.num-header { font-size:22rpx; color:#64909A; border-bottom:1rpx solid rgba(255,255,255,0.15) !important; }
.wood-row  text:first-child { color:#4CAF50; font-weight:700; }
.fire-row  text:first-child { color:#F44336; font-weight:700; }
.earth-row text:first-child { color:#FF9800; font-weight:700; }
.metal-row text:first-child { color:#90A4AE; font-weight:700; }
.water-row text:first-child { color:#2196F3; font-weight:700; }
.num-row text:not(:first-child) { color:#C8D8E8; font-family:monospace; }

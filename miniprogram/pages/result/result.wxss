/* pages/result/result.wxss */
.page { min-height:100vh; background:#1A2744; padding-bottom:130rpx; }

/* Tab 栏 */
.tab-bar { display:flex; background:#243560; position:sticky; top:0; z-index:10; }
.tab-item { flex:1; text-align:center; padding:30rpx 0; font-size:32rpx; color:#94B8D0; position:relative; transition:color 0.2s; }
.tab-on { color:#FFD700; font-weight:700; }
.tab-on::after { content:''; position:absolute; bottom:0; left:15%; right:15%; height:4rpx; background:linear-gradient(90deg,transparent,#FFD700,transparent); border-radius:2rpx; animation:tabIndicator 0.25s ease-out; }

@keyframes tabIndicator {
  from { opacity:0; transform:scaleX(0.3); }
  to   { opacity:1; transform:scaleX(1); }
}

.tab-body { padding:24rpx 28rpx; }

/* 日期横幅 */
.date-banner { border-radius:20rpx; padding:24rpx 28rpx; margin-bottom:20rpx; display:flex; align-items:center; justify-content:space-between; }
.birth-banner   { background:linear-gradient(135deg,#2A3D60,#1E2E4E); border:1rpx solid rgba(255,215,0,0.3); }
.disease-banner { background:linear-gradient(135deg,#3D2A2A,#2E1E1E); border:1rpx solid rgba(244,67,54,0.3); }
.banner-date { font-size:38rpx; font-weight:800; color:#E8F4F8; }
.banner-gz   { font-size:26rpx; color:#94B8D0; }

/* 数据卡 */
.data-card { background:#243560; border-radius:20rpx; padding:24rpx 28rpx; margin-bottom:20rpx; }
.card-title { display:block; font-size:26rpx; font-weight:700; color:#FFD700; margin-bottom:20rpx; letter-spacing:2rpx; }
.data-row { display:flex; align-items:center; padding:14rpx 0; border-bottom:1rpx solid rgba(255,255,255,0.06); }
.data-row:last-child { border-bottom:none; }
.dk { width:72rpx; font-size:24rpx; color:#94B8D0; flex-shrink:0; }
.dv { flex:1; font-size:28rpx; font-weight:600; color:#E8F4F8; }
.dv.gold, .gold { color:#FFD700; }
.dnum { font-size:24rpx; color:#FFD700; font-family:monospace; letter-spacing:2rpx; }

/* Canvas 图表区域 */
.chart-wrap {
  position:relative;
  margin-bottom:20rpx;
  border-radius:16rpx;
  overflow:hidden;
  /* 按压反馈 */
  transition:transform 0.15s, box-shadow 0.15s;
  box-shadow:0 4rpx 24rpx rgba(0,0,0,0.35);
}
.chart-wrap:active {
  transform:scale(0.975);
  box-shadow:0 2rpx 12rpx rgba(0,0,0,0.5);
}

/* 图表入场动画 */
@keyframes chartEnter {
  from { opacity:0; transform:scale(0.93) translateY(16rpx); }
  to   { opacity:1; transform:scale(1) translateY(0); }
}
.chart-enter { animation:chartEnter 0.4s cubic-bezier(0.22,1,0.36,1) forwards; }

.qi-canvas { width:100%; aspect-ratio:1; display:block; border-radius:16rpx; background:#0D1B2A; }

/* 展开提示角标 */
.expand-hint {
  position:absolute;
  bottom:20rpx; right:20rpx;
  display:flex;
  align-items:center;
  gap:8rpx;
  background:rgba(13,27,42,0.72);
  border:1rpx solid rgba(255,215,0,0.25);
  border-radius:24rpx;
  padding:10rpx 22rpx;
  backdrop-filter:blur(4px);
}
.expand-icon { font-size:26rpx; color:#FFD700; }
.expand-text { font-size:20rpx; color:#94B8D0; }

/* 六气表 */
.qi-table-card { background:#243560; border-radius:20rpx; padding:24rpx 28rpx; margin-bottom:20rpx; }
.qi-table-row { display:grid; grid-template-columns:1.4fr 2fr 2fr; padding:12rpx 0; font-size:24rpx; color:#94B8D0; border-bottom:1rpx solid rgba(255,255,255,0.05); }
.header-row { color:#64909A; font-size:22rpx; border-bottom:1rpx solid rgba(255,255,255,0.12) !important; }
.row-on { color:#E8F4F8; background:rgba(255,215,0,0.08); border-radius:8rpx; padding:12rpx 8rpx; }
.col-label { font-weight:600; }

/* 对比 */
.cmp-header { display:flex; gap:16rpx; margin:20rpx 0 16rpx; }
.cmp-col { flex:1; padding:20rpx; border-radius:16rpx; text-align:center; }
.birth-col   { background:rgba(255,215,0,0.1); }
.disease-col { background:rgba(244,67,54,0.1); }
.cmp-title { display:block; font-size:32rpx; font-weight:800; margin-bottom:6rpx; }
.birth-col   .cmp-title { color:#FFD700; }
.disease-col .cmp-title { color:#F44336; }
.cmp-sub { font-size:22rpx; color:#94B8D0; }

.cmp-row { display:grid; grid-template-columns:72rpx 1fr 1fr; padding:14rpx 0; font-size:26rpx; border-bottom:1rpx solid rgba(255,255,255,0.05); align-items:center; }
.ck { color:#94B8D0; font-size:24rpx; }
.cv { text-align:center; color:#E8F4F8; font-size:24rpx; }
.birth-cv   { color:#FFD700; font-weight:700; }
.disease-cv { color:#F44336; font-weight:700; }

/* 李阳波 */
.yangbo-row { display:flex; gap:16rpx; }
.yangbo-box { flex:1; padding:20rpx; border-radius:14rpx; }
.birth-box   { background:rgba(255,215,0,0.08); }
.disease-box { background:rgba(244,67,54,0.08); }
.yangbo-tag { display:block; font-size:28rpx; font-weight:800; margin-bottom:10rpx; }
.birth-box   .yangbo-tag { color:#FFD700; }
.disease-box .yangbo-tag { color:#F44336; }
.yangbo-nums { display:block; font-size:26rpx; font-family:monospace; color:#E8F4F8; line-height:1.8; word-break:break-all; letter-spacing:4rpx; }

/* 五行权重 */
.weight-row { display:flex; align-items:center; margin-bottom:16rpx; }
.weight-el { width:48rpx; font-size:28rpx; font-weight:800; }
.weight-bars { flex:1; display:flex; flex-direction:column; gap:6rpx; }
.w-bar { height:28rpx; border-radius:4rpx; min-width:16rpx; display:flex; align-items:center; padding-left:8rpx; transition:width 0.45s cubic-bezier(0.22,1,0.36,1); }
.birth-bar   { background:linear-gradient(90deg,rgba(255,215,0,0.5),rgba(255,215,0,0.2)); }
.disease-bar { background:linear-gradient(90deg,rgba(244,67,54,0.5),rgba(244,67,54,0.2)); }
.w-num { font-size:20rpx; color:#E8F4F8; font-weight:700; }
.weight-legend { display:flex; flex-direction:column; gap:6rpx; margin-left:12rpx; }
.wl-birth   { font-size:18rpx; color:rgba(255,215,0,0.7); }
.wl-disease { font-size:18rpx; color:rgba(244,67,54,0.7); }

/* ===== 全屏蒙层 ===== */
.chart-fullscreen {
  position:fixed; top:0; left:0; right:0; bottom:0;
  z-index:9999;
  background:#0D1B2A;
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  opacity:0;
  pointer-events:none;
  transition:opacity 0.3s ease;
}
.fs-visible {
  opacity:1;
  pointer-events:auto;
}

/* 全屏头部 */
.fs-header {
  width:100%;
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:24rpx 32rpx 16rpx;
  flex-shrink:0;
}
.fs-title-wrap { display:flex; align-items:center; gap:16rpx; }
.fs-badge {
  width:52rpx; height:52rpx;
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:28rpx; font-weight:800;
  line-height:52rpx;
  text-align:center;
}
.fs-badge-birth   { background:rgba(255,215,0,0.15); color:#FFD700; border:1rpx solid rgba(255,215,0,0.4); }
.fs-badge-disease { background:rgba(244,67,54,0.15);  color:#F44336; border:1rpx solid rgba(244,67,54,0.4); }
.fs-title { font-size:32rpx; font-weight:700; color:#E8F4F8; }
.fs-close-btn { padding:16rpx; }
.fs-close { font-size:40rpx; color:#64909A; }

/* 全屏 Canvas 容器 */
.fs-canvas-wrap {
  flex:1;
  display:flex;
  align-items:center;
  justify-content:center;
  width:100%;
  overflow:hidden;
  padding:0 16rpx;
  position:relative;
}
.fs-canvas {
  display:block;
  max-width:100%;
  max-height:100%;
  border-radius:20rpx;
  box-shadow:0 0 60rpx rgba(0,0,0,0.6);
}
/* 透明点击层，覆盖 canvas 以接管 tap 事件（canvas 是原生组件会吞噬 tap） */
.fs-tap-catcher {
  position:absolute;
  top:0; left:0; right:0; bottom:0;
  z-index:1;
}

/* 全屏底部提示 */
.fs-footer {
  padding:20rpx 32rpx 32rpx;
  display:flex;
  align-items:center;
  gap:8rpx;
  flex-shrink:0;
}
.fs-hint { font-size:22rpx; color:rgba(148,184,208,0.7); }
.fs-close-hint { font-size:22rpx; color:rgba(148,184,208,0.4); }

/* 全屏蒙层内容入场动画 */
.fs-visible .fs-canvas-wrap {
  animation:fsCanvasIn 0.4s cubic-bezier(0.22,1,0.36,1) forwards;
}
@keyframes fsCanvasIn {
  from { transform:scale(0.88); opacity:0; }
  to   { transform:scale(1);    opacity:1; }
}

/* 分享 */
.share-bar { position:fixed; bottom:0; left:0; right:0; padding:20rpx 28rpx; background:#1A2744; border-top:1rpx solid rgba(255,255,255,0.08); }
.share-btn { background:linear-gradient(135deg,#243560,#2E4070); color:#FFD700; border:1rpx solid rgba(255,215,0,0.35); border-radius:16rpx; font-size:30rpx; padding:22rpx; width:100%; }

/* 可点击术语 */
.clickable { border-bottom: 1rpx solid rgba(255,215,0,0.35); padding-bottom: 2rpx; }

/* ===== 纯 CSS 五行图（替代 Canvas）===== */

.qi-chart {
  position: relative;
  width: 680rpx;
  height: 680rpx;
  margin: 0 auto;
  background: radial-gradient(ellipse at 50% 42%, #0F1E35 0%, #070E1C 75%);
  border-radius: 20rpx;
  font-size: 26rpx;
}
.qi-chart-lg {
  width: 92vw;
  height: 92vw;
  font-size: 34rpx;
  border-radius: 24rpx;
}

/* 连接线 */
.qi-lv {
  position: absolute;
  left: 50%; top: 18%; bottom: 18%;
  width: 1rpx;
  transform: translateX(-50%);
  background: linear-gradient(to bottom,
    transparent 0%,
    rgba(255,215,0,0.14) 20%,
    rgba(255,215,0,0.14) 80%,
    transparent 100%);
  pointer-events: none;
}
.qi-lh {
  position: absolute;
  top: 50%; left: 18%; right: 18%;
  height: 1rpx;
  transform: translateY(-50%);
  background: linear-gradient(to right,
    transparent 0%,
    rgba(255,215,0,0.14) 20%,
    rgba(255,215,0,0.14) 80%,
    transparent 100%);
  pointer-events: none;
}

/* 方位字 */
.qi-dir {
  position: absolute;
  font-size: 0.8em;
  color: rgba(255,215,0,0.4);
  font-weight: 700;
  pointer-events: none;
}
.qi-dir-s { top: 3%;    left: 50%;  transform: translateX(-50%); }
.qi-dir-n { bottom: 3%; left: 50%;  transform: translateX(-50%); }
.qi-dir-e { top: 50%;   left: 3%;   transform: translateY(-50%); }
.qi-dir-w { top: 50%;   right: 3%;  transform: translateY(-50%); }

/* 节点定位容器 */
.qi-pos {
  position: absolute;
  width: 28%;
  height: 28%;
  transform: translate(-50%, -50%);
}
.qi-pf { left: 50%; top: 18%; }   /* 火：南（上）*/
.qi-pw { left: 50%; top: 82%; }   /* 水：北（下）*/
.qi-pm { left: 18%; top: 50%; }   /* 木：东（左）*/
.qi-pe { left: 50%; top: 50%; }   /* 土：中 */
.qi-pk { left: 82%; top: 50%; }   /* 金：西（右）*/

/* 节点容器 */
.qn-wrap {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 核心圆 */
.qn-circle {
  position: relative;
  z-index: 1;
  width: 72%;
  height: 72%;
  border-radius: 50%;
  border-width: 2rpx;
  border-style: solid;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 能量环（从内向外，随引用次数增加） */
.qn-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border-style: solid;
  border-width: 1.5rpx;
  pointer-events: none;
  box-sizing: border-box;
  flex-shrink: 0;
}
.qn-r1 { width: 84%;  height: 84%; }
.qn-r2 { width: 100%; height: 100%; }
.qn-r3 { width: 116%; height: 116%; }

/* 节点文字 */
.qn-el   { font-size: 1.6em; font-weight: 900; line-height: 1; }
.qn-zang { font-size: 0.7em; color: rgba(232,244,248,0.65); line-height: 1.2; margin-top: 2rpx; }
.qn-fu   { font-size: 0.7em; color: rgba(232,244,248,0.4);  line-height: 1.2; }

/* ── 原生底部弹窗 ── */
.popup-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0);
  z-index: 10000;
  pointer-events: none;
  transition: background 0.28s;
}
.popup-mask-show {
  background: rgba(0,0,0,0.55);
  pointer-events: auto;
}
.popup-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  z-index: 10001;
  background: #1C2D52;
  border-radius: 32rpx 32rpx 0 0;
  border-top: 2rpx solid rgba(255,215,0,0.28);
  transform: translateY(100%);
  transition: transform 0.30s cubic-bezier(0.32,0.72,0,1);
  max-height: 75vh;
  overflow: hidden;
}
.popup-sheet-show { transform: translateY(0); }
.popup-bar {
  display: flex; align-items: center; justify-content: center;
  padding: 20rpx 28rpx 8rpx;
  position: relative;
}
.popup-drag-handle {
  width: 72rpx; height: 8rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 4rpx;
}
.popup-close-btn {
  position: absolute; right: 28rpx; top: 16rpx;
  padding: 10rpx 14rpx;
}
.popup-close-x { font-size: 34rpx; color: #64909A; }

/* 弹窗内容 */
.explain-popup { padding: 16rpx 36rpx 60rpx; overflow-y: auto; max-height: calc(75vh - 80rpx); }
.ep-title { font-size: 40rpx; font-weight: 800; color: #FFD700; margin-bottom: 12rpx; letter-spacing: 2rpx; }
.ep-subtitle { font-size: 24rpx; color: #94B8D0; margin-bottom: 24rpx; line-height: 1.5; }
.ep-body { font-size: 28rpx; color: #E8F4F8; line-height: 1.9; white-space: pre-wrap; }

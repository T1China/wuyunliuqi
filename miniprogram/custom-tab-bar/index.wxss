/* custom-tab-bar/index.wxss */
.tab-bar {
  display: flex;
  height: 120rpx;
  background: #1A2744;
  border-top: 1rpx solid rgba(255,255,255,0.1);
  padding-bottom: env(safe-area-inset-bottom);
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding-top: 10rpx;
}
.tab-item:active { opacity: 0.7; }
.tab-icon {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 6rpx;
  filter: grayscale(80%);
}
.tab-text {
  font-size: 24rpx;
  color: #607D8B;
  font-weight: 500;
}
.tab-on .tab-icon { filter: none; }
.tab-on .tab-text {
  color: #FFD700;
  font-weight: 700;
}
.tab-dot {
  position: absolute;
  bottom: 6rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FFD700;
}
